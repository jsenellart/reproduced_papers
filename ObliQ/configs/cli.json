{
  "description": "ObliQ QUBO generator and classical solvers",
  "arguments": [
    {
      "flags": ["--problem.type"],
      "help": "Problem type: random or graph-coloring",
      "type": "str",
      "default": null,
      "apply": {"kind": "config_path", "path": "problem.type"}
    },
    {
      "flags": ["--problem.size"],
      "help": "Number of binary variables for random QUBO",
      "type": "int",
      "default": null,
      "apply": {"kind": "config_path", "path": "problem.size"}
    },
    {
      "flags": ["--problem.penalty"],
      "help": "Penalty coefficient for constraint violations",
      "type": "float",
      "default": null,
      "apply": {"kind": "config_path", "path": "problem.penalty"}
    },
    {
      "flags": ["--graph.num-nodes"],
      "help": "Node count for graph-coloring instances",
      "type": "int",
      "default": null,
      "apply": {"kind": "config_path", "path": "problem.graph.num_nodes"}
    },
    {
      "flags": ["--graph.num-colors"],
      "help": "Color count for graph-coloring instances",
      "type": "int",
      "default": null,
      "apply": {"kind": "config_path", "path": "problem.graph.num_colors"}
    },
    {
      "flags": ["--graph.edge-prob"],
      "help": "Edge probability for random graph generation (MaxCut)",
      "type": "float",
      "default": null,
      "apply": {"kind": "config_path", "path": "problem.graph.edge_prob"}
    },
    {
      "flags": ["--solver.method"],
      "help": "Solver: exhaustive, annealing, obliq, obliq-static, or vqc",
      "type": "str",
      "default": null,
      "apply": {"kind": "config_path", "path": "solver.method"}
    },
    {
      "flags": ["--solver.annealing.max-iter"],
      "help": "Iterations for annealing",
      "type": "int",
      "default": null,
      "apply": {"kind": "config_path", "path": "solver.configs.annealing.max_iter"}
    },
    {
      "flags": ["--solver.annealing.restarts"],
      "help": "Number of annealing restarts",
      "type": "int",
      "default": null,
      "apply": {"kind": "config_path", "path": "solver.configs.annealing.restarts"}
    },
    {
      "flags": ["--solver.annealing.temperature"],
      "help": "Initial temperature for annealing",
      "type": "float",
      "default": null,
      "apply": {"kind": "config_path", "path": "solver.configs.annealing.temperature"}
    },
    {
      "flags": ["--solver.annealing.cooling"],
      "help": "Cooling rate for annealing",
      "type": "float",
      "default": null,
      "apply": {"kind": "config_path", "path": "solver.configs.annealing.cooling"}
    },
    {
      "flags": ["--solver.obliq-static.nsamples"],
      "help": "Photonic samples/shots for obliq-static",
      "type": "int",
      "default": null,
      "apply": {"kind": "config_path", "path": "solver.configs.obliq-static.nsamples"}
    },
    {
      "flags": ["--solver.obliq-static.restarts"],
      "help": "Random restarts for obliq-static parameter sweeps",
      "type": "int",
      "default": null,
      "apply": {"kind": "config_path", "path": "solver.configs.obliq-static.restarts"}
    },
    {
      "flags": ["--solver.obliq.nsamples"],
      "help": "Photonic samples/shots for hybrid ObliQ",
      "type": "int",
      "default": null,
      "apply": {"kind": "config_path", "path": "solver.configs.obliq.nsamples"}
    },
    {
      "flags": ["--solver.obliq.restarts"],
      "help": "Random restarts for hybrid ObliQ VQC refinement",
      "type": "int",
      "default": null,
      "apply": {"kind": "config_path", "path": "solver.configs.obliq.restarts"}
    },
    {
      "flags": ["--solver.vqc.nsamples"],
      "help": "Photonic samples/shots for standalone VQC",
      "type": "int",
      "default": null,
      "apply": {"kind": "config_path", "path": "solver.configs.vqc.nsamples"}
    },
    {
      "flags": ["--solver.vqc.restarts"],
      "help": "Random restarts for standalone VQC",
      "type": "int",
      "default": null,
      "apply": {"kind": "config_path", "path": "solver.configs.vqc.restarts"}
    }
  ]
}
