{
  "description": "QRNN paper reproduction runner",
  "arguments": [
    {
      "flags": ["--epochs"],
      "help": "Override number of training epochs",
      "type": "int",
      "default": null,
      "apply": {"kind": "config_path", "path": "training.epochs"}
    },
    {
      "flags": ["--batch-size"],
      "help": "Override dataset batch size",
      "type": "int",
      "default": null,
      "apply": {"kind": "config_path", "path": "dataset.batch_size"}
    },
    {
      "flags": ["--sequence-length"],
      "help": "Length of the input weather history used for forecasting",
      "type": "int",
      "default": null,
      "apply": {"kind": "config_path", "path": "dataset.sequence_length"}
    },
    {
      "flags": ["--hidden-dim"],
      "help": "Hidden dimension for the RNN baseline",
      "type": "int",
      "default": null,
      "apply": {"kind": "config_path", "path": "model.params.hidden_dim"}
    },
    {
      "flags": ["--lr"],
      "help": "Override learning rate",
      "type": "float",
      "default": null,
      "apply": {"kind": "config_path", "path": "training.lr"}
    }
  ]
}
