{
  "description": "Example MaxCut instance on an Erdos-Renyi graph",
  "problem": {
    "type": "maxcut",
    "graph": {
      "num_nodes": 8,
      "edge_prob": 0.4
    }
  },
  "solver": {
    "method": "annealing",
    "configs": {
      "annealing": {
        "max_iter": 1500,
        "temperature": 1.2,
